LLM_PROVIDER=openai
OPENAI_API_KEY=your_litellm_or_openai_key
LITELLM_TOKEN=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://litellm.oit.duke.edu
# LITELLM_BASE_URL=https://litellm.oit.duke.edu

# Or switch provider:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

MAX_CONTEXT_MESSAGES=5
MAX_BODY_CHARS=1200

# Google OAuth - set GOOGLE_CLIENT_SECRET_JSON to your credentials JSON content
# Download from Google Cloud Console and set as environment variable
# Format: {"installed": {"client_id": "...", "client_secret": "...", ...}}
GOOGLE_CLIENT_SECRET_JSON=
GOOGLE_TOKEN_FILE=token.json
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/google/callback
